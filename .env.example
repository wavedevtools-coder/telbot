# =============================================
#   Telegram Image-to-Video Bot - Config
# =============================================

# --- REQUIRED ---
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --- OPTIONAL ---
# Path to ffmpeg binary if not already in PATH
FFMPEG_PATH=ffmpeg
